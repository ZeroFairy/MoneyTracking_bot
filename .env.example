# Copy this file to ".env" and fill in your own values.

# From @BotFather on Telegram after you create your bot
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenGoesHere

# The long ID in your Google Sheet's URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SHEETS_ID=

# Path to the service account JSON key file (see README.md)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Optional: restrict the bot to specific chats only.
# Comma-separated Telegram chat IDs (your personal chat ID and/or group IDs).
# Leave empty to allow anyone who finds the bot to use it (not recommended).
ALLOWED_CHAT_IDS=
